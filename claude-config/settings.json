{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "MultiEdit",
      "Edit",
      "Write",
      "LS",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:pytorch.org)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(/usr/bin/grep *)",
      "Bash(whoami)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(whoami)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tmux capture-pane:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.zshenv)",
      "Read(**/id_rsa)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python ~/.claude/hooks/audit_edit.py"}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash ~/.claude/hooks/enforce-tmux.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {"type": "command", "command": "bash ~/.claude/hooks/cc-changes-log.sh"}
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {"type": "command", "command": "bash ~/.claude/hooks/cc-bridge-hook.sh prompt-submit"}
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {"type": "command", "command": "bash ~/.claude/hooks/cc-bridge-hook.sh notify"}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "bash ~/.claude/hooks/cc-bridge-hook.sh stop"}
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "tui": "default"
}
